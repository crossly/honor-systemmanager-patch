#!/sbin/sh

OUTFD=$2
ZIPFILE=$3
[ -n "$ZIPFILE" ] || ZIPFILE="$1"

ui_print() {
  echo "ui_print $1" > /proc/self/fd/$OUTFD
  echo "ui_print" > /proc/self/fd/$OUTFD
}

abort() {
  ui_print "$1"
  exit 1
}

set_perm() {
  chown "$2:$3" "$1" || true
  chmod "$4" "$1" || true
}

set_perm_recursive() {
  chown -R "$2:$3" "$1" || true
  find "$1" -type d -exec chmod "$4" {} \; || true
  find "$1" -type f -exec chmod "$5" {} \; || true
}

MODID="honor-systemmanager-patch"
MODPATH="/data/adb/modules_update/$MODID"
[ -d /data/adb/modules_update ] || MODPATH="/data/adb/modules/$MODID"

rm -rf "$MODPATH"
mkdir -p "$MODPATH" || abort "Cannot create $MODPATH"

unzip -o "$ZIPFILE" customize.sh -d "$MODPATH" >&2 || abort "Cannot extract customize.sh"
. "$MODPATH/customize.sh"

on_install
set_permissions

ui_print "Install finished."
exit 0
